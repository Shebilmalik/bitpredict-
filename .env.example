# =============================================
# BitPredict — Environment Configuration
# =============================================
# Copy this file to .env and fill in values

# ── CONTRACT (fill after deploying) ──────────
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── OP_NET RPC ENDPOINTS ─────────────────────
OPNET_REGTEST_RPC=http://localhost:9944
OPNET_REGTEST_CHAIN_ID=1

OPNET_TESTNET_RPC=https://testnet.opnet.org
OPNET_TESTNET_CHAIN_ID=3

OPNET_MAINNET_RPC=https://rpc.opnet.org
OPNET_MAINNET_CHAIN_ID=1

# ── DEPLOYER ─────────────────────────────────
# NEVER commit this to git — add .env to .gitignore
PRIVATE_KEY=your_wallet_private_key_here
